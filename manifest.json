{
  "manifest_version": 3,
  "name": "NotionDictionary",
  "version": "1.0",
  "description": "Select any word on any webpage and save it to your Notion vocabulary database — complete with definition, pronunciation, synonyms, antonyms, and translation.",
  "homepage_url": "https://github.com/furkansina/dictionary_extension",
  "permissions": ["activeTab", "scripting", "storage"],
  "icons": {
    "16": "images/icon16.png",
    "48": "images/icon48.png",
    "128": "images/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "images/icon16.png",
      "48": "images/icon48.png",
      "128": "images/icon128.png"
    },
    "default_popup": "popup.html"
  },
  "host_permissions": [
      "https://api.notion.com/*",
      "https://api.dictionaryapi.dev/*",
      "https://api.mymemory.translated.net/*"
  ],
  "background": {
      "service_worker": "scripts/background.js"
  },
  "content_scripts": [
      {
          "matches": ["<all_urls>"],
          "js": ["scripts/content.js"]
      }
  ],
  "web_accessible_resources": [
      {
          "resources": ["images/*.png"],
          "matches": ["<all_urls>"]
      }
  ]
}